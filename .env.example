# Copy this file to .env.local for local development (npm run dev),
# and set the same values under Vercel Project Settings -> Environment
# Variables for production/preview.

# Get a key at https://resend.com (free tier covers low-volume form traffic)
RESEND_API_KEY=

# Where form submissions get sent -- the firm's real inbox
CONTACT_TO_EMAIL=

# Must be a domain you've verified in Resend. Until you verify barimolaw.com
# in Resend, you can leave this unset and it'll default to Resend's shared
# onboarding@resend.dev sender for testing.
CONTACT_FROM_EMAIL=
